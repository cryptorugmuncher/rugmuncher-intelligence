# RMI v2 API Configuration

# App
APP_NAME="RMI Intelligence API"
APP_VERSION="2.0.0"
DEBUG=true
ENV=development

# Database (PostgreSQL - required format)
DATABASE_URL=postgresql://rmi_user:rmi_pass@localhost:5432/rmi_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_MAX_LEN=10000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security (32+ chars)
SECRET_KEY=dev-secret-key-change-in-production-immediately!

